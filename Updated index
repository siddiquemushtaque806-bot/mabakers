function renderCustomerHistory() {
    const name = state.historyCustomer;
    if (!name) return;

    const from    = v('ch-from');
    const to      = v('ch-to');
    const daily   = state.data.daily;
    const content = document.getElementById('ch-content');

    // Get dates in range, ascending
    const dates = Object.keys(daily)
        .filter(d => daily[d][name] !== undefined && d >= from && d <= to)
        .sort();

    if (!dates.length) {
        content.innerHTML = '<div class="empty-state">No entries found for this period</div>';
        return;
    }

    // Accumulate totals
    let totals = { smallQty:0, largeQty:0, burgerQty:0, butterQty:0, mayoQty:0,
                   smallAmt:0, largeAmt:0, burgerAmt:0, butterAmt:0, mayoAmt:0,
                   rent:0, paid:0, dayTotal:0 };

    // Build entry cards (newest first)
    const entryCards = [...dates].reverse().map(d => {
        const e = daily[d][name];

        totals.smallQty  += e.shawarma_small_qty   || 0;
        totals.largeQty  += e.shawarma_large_qty   || 0;
        totals.burgerQty += e.burger_qty            || 0;
        totals.butterQty += e.butter_qty            || 0;
        totals.mayoQty   += e.mayo_qty              || 0;
        totals.smallAmt  += e.shawarma_small_total  || 0;
        totals.largeAmt  += e.shawarma_large_total  || 0;
        totals.burgerAmt += e.burger_total          || 0;
        totals.butterAmt += e.butter_total          || 0;
        totals.mayoAmt   += e.mayo_total            || 0;
        totals.rent      += e.rent                  || 0;
        totals.paid      += e.payment               || 0;
        totals.dayTotal  += e.day_total             || 0;

        let details = '';
        if (e.shawarma_small_qty)  details += `<div class="row-sub">🫓 Small: ${e.shawarma_small_qty} = ${fmtMoney(e.shawarma_small_total || 0)}</div>`;
        if (e.shawarma_large_qty)  details += `<div class="row-sub">🫓 Large: ${e.shawarma_large_qty} = ${fmtMoney(e.shawarma_large_total || 0)}</div>`;
        if (e.burger_qty)          details += `<div class="row-sub">🍔 Burger: ${e.burger_qty} = ${fmtMoney(e.burger_total || 0)}</div>`;
        if (e.butter_qty)          details += `<div class="row-sub">🧻 Butter: ${e.butter_qty} = ${fmtMoney(e.butter_total || 0)}</div>`;
        if (e.mayo_qty)            details += `<div class="row-sub">🥫 Mayo: ${e.mayo_qty} = ${fmtMoney(e.mayo_total || 0)}</div>`;
        if (e.rent)                details += `<div class="row-sub">🏠 Rent: ${fmtMoney(e.rent)}</div>`;

        const ownerDetails = state.role === 'owner'
            ? `<div class="row-sub" style="color:var(--green);margin-top:4px">💵 Payment: ${fmtMoney(e.payment || 0)}</div>
               <div class="row-sub">Prev Balance: ${fmtMoney(e.prev_outstanding || 0)}</div>
               <div class="row-sub" style="color:${(e.outstanding||0) <= 0 ? 'var(--green)' : 'var(--gold-light)'}">
                   Outstanding: ${(e.outstanding||0) <= 0 ? 'PAID ✓' : fmtMoney(e.outstanding)}
               </div>`
            : '';

        return `<div class="history-entry">
                    <div class="history-date">${d}</div>
                    ${details}
                    <div class="row-sub" style="color:var(--gold-light);font-weight:600;margin-top:6px">
                        Day Total: ${fmtMoney(e.day_total || 0)}
                    </div>
                    ${ownerDetails}
                </div>`;
    }).join('');

    // Latest outstanding (across all time, not just range)
    const allDates    = Object.keys(daily).filter(d => daily[d][name]).sort();
    const latestEntry = allDates.length ? daily[allDates[allDates.length - 1]][name] : null;
    const latestOut   = latestEntry ? (latestEntry.outstanding || 0) : 0;

    const ownerSummary = state.role === 'owner'
        ? `<div class="stat-cell"><div class="stat-label">Total Paid</div><div class="stat-value green">${fmtMoney(totals.paid)}</div></div>
           <div class="stat-cell accent span2"><div class="stat-label">Current Outstanding</div>
               <div class="stat-value ${latestOut <= 0 ? 'green' : 'gold'}">${latestOut <= 0 ? 'PAID ✓' : fmtMoney(latestOut)}</div>
           </div>`
        : '';

    const billBtn = `<button class="btn btn-primary" style="margin-top:14px"
        onclick="generateBill('${name}','${from}','${to}')">📄 Generate Bill</button>`;

    content.innerHTML = `
        <div class="card-premium">
            <div class="hero">
                <div class="hero-label">Total Business</div>
                <div class="hero-value">${fmtMoney(totals.dayTotal)}</div>
            </div>
            <div class="gold-rule"></div>
            <div class="stat-grid">
                <div class="stat-cell"><div class="stat-label">Small</div><div class="stat-value">${totals.smallQty} pcs<br>${fmtMoney(totals.smallAmt)}</div></div>
                <div class="stat-cell"><div class="stat-label">Large</div><div class="stat-value">${totals.largeQty} pcs<br>${fmtMoney(totals.largeAmt)}</div></div>
                <div class="stat-cell"><div class="stat-label">Burger</div><div class="stat-value">${totals.burgerQty} pcs<br>${fmtMoney(totals.burgerAmt)}</div></div>
                <div class="stat-cell"><div class="stat-label">Butter</div><div class="stat-value">${totals.butterQty} pcs<br>${fmtMoney(totals.butterAmt)}</div></div>
                <div class="stat-cell"><div class="stat-label">Mayo</div><div class="stat-value">${totals.mayoQty} pcs<br>${fmtMoney(totals.mayoAmt)}</div></div>
                <div class="stat-cell"><div class="stat-label">Rent</div><div class="stat-value">${fmtMoney(totals.rent)}</div></div>
                ${ownerSummary}
            </div>
            ${billBtn}
        </div>
        <div class="card-label" style="margin-bottom:8px">📋 Entries — ${dates.length} days</div>
        ${entryCards}
    `;
}

