<script>
'use strict';

const PASSWORDS        = { '0000': 'manager', '9900': 'owner' };
const SYNC_URL         = 'https://mabakers.bonto.run/api/sync';
const SYNC_INTERVAL_MS = 5 * 60 * 1000;

let state = {
    data:            { customers: {}, daily: {} },
    role:            null,
    syncTimer:       null,
    editingCustomer: null,
    historyCustomer: null,
    currentBillName: null,
    currentBillFrom: null,
    currentBillTo:   null,
};

function persistData() {
    const json = JSON.stringify(state.data);
    try {
        if (window.AndroidBridge) window.AndroidBridge.saveData(json);
        else localStorage.setItem('mabakers_v2', json);
    } catch (_) { localStorage.setItem('mabakers_v2', json); }
}

function loadData() {
    try {
        let raw = null;
        if (window.AndroidBridge) raw = window.AndroidBridge.loadData();
        if (!raw) raw = localStorage.getItem('mabakers_v2') || localStorage.getItem('mabakers');
        if (raw) {
            const parsed = JSON.parse(raw);
            if (isValidAppData(parsed)) state.data = parsed;
        }
    } catch (_) {}
}

function isValidAppData(o) {
    return o && typeof o === 'object'
        && typeof o.customers === 'object'
        && typeof o.daily     === 'object';
}

function todayISO()     { return new Date().toISOString().split('T')[0]; }
function firstOfMonth() { const d = new Date(); return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-01'; }
function fmtMoney(n)    { return 'Rs ' + Math.round(n).toLocaleString('en-PK'); }
function n(id)          { return parseFloat(document.getElementById(id).value) || 0; }
function v(id)          { return (document.getElementById(id).value || '').trim(); }
function set(id, val)   { document.getElementById(id).value = val; }

let _toastTimer = null;
function showToast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

let _statusTimers = {};
function showStatus(id, msg, type) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg;
    el.className = 'status-bar show ' + type;
    clearTimeout(_statusTimers[id]);
    _statusTimers[id] = setTimeout(() => el.classList.remove('show'), 4000);
}

function navigateTo(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
    const pageEl = document.getElementById('page-' + page);
    const navEl  = document.getElementById('nav-'  + page);
    if (pageEl) pageEl.classList.add('active');
    if (navEl)  navEl.classList.add('active');
    if (page === 'daily')       buildQuickList();
    if (page === 'outstanding') renderOutstanding();
    if (page === 'payments')    buildPaymentList();
}

function shiftDate(inputId, delta) {
    const el = document.getElementById(inputId);
    const d  = new Date(el.value);
    d.setDate(d.getDate() + delta);
    el.value = d.toISOString().split('T')[0];
}

function handleLogin() {
    const pwd  = document.getElementById('login-input').value;
    const role = PASSWORDS[pwd];
    if (role) {
        state.role = role;
        localStorage.setItem('ma_role', role);
        applyRole();
        document.getElementById('login-screen').classList.add('hidden');
        startAutoSync();
        buildQuickList();
    } else {
        const errEl = document.getElementById('login-error');
        errEl.classList.add('show');
        document.getElementById('login-input').value = '';
        setTimeout(() => errEl.classList.remove('show'), 2500);
    }
}

function handleLogout() {
    state.role = null;
    localStorage.removeItem('ma_role');
    stopAutoSync();
    document.getElementById('login-input').value = '';
    document.getElementById('login-screen').classList.remove('hidden');
    showToast('Logged out');
}

function applyRole() {
    const mgr = state.role === 'manager';
    document.body.classList.toggle('manager-mode', mgr);
    document.getElementById('header-role').textContent = mgr ? 'Manager' : 'Owner';
}

function startAutoSync() {
    stopAutoSync();
    state.syncTimer = setInterval(syncSilent, SYNC_INTERVAL_MS);
}
function stopAutoSync() {
    if (state.syncTimer) { clearInterval(state.syncTimer); state.syncTimer = null; }
}

async function syncSilent() {
    try {
        const res = await fetch(SYNC_URL, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(state.data) });
        if (res.ok) { const m = await res.json(); if (isValidAppData(m)) { state.data = m; persistData(); refreshAllViews(); } }
    } catch (_) {}
}

async function syncData() {
    showToast('Syncing…');
    try {
        const res = await fetch(SYNC_URL, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(state.data) });
        if (!res.ok) { showToast('Sync failed'); return; }
        const m = await res.json();
        if (isValidAppData(m)) { state.data = m; persistData(); refreshAllViews(); showToast('✓ Synced'); }
        else showToast('Sync error — data protected');
    } catch (_) { showToast('No internet'); }
}

function refreshAllViews() { renderCustomerList(); renderOutstanding(); buildQuickList(); }

function getPrevOutstanding(name, date) {
    const daily = state.data.daily;
    const prior = Object.keys(daily).filter(d => daily[d][name] !== undefined && d < date).sort();
    if (prior.length) return daily[prior[prior.length-1]][name].outstanding || 0;
    return (state.data.customers[name] || {}).opening_outstanding || 0;
}

function cascadeRecalc(name, fromDate) {
    const daily   = state.data.daily;
    const futures = Object.keys(daily).filter(d => daily[d][name] !== undefined && d > fromDate).sort();
    for (const date of futures) {
        const e   = daily[date][name];
        const po  = getPrevOutstanding(name, date);
        e.prev_outstanding = po;
        e.outstanding      = po + e.day_total - e.payment;
    }
}

function buildQuickList() {
    const date     = document.getElementById('quick-date').value;
    const container= document.getElementById('quick-list');
    const names    = Object.keys(state.data.customers);
    if (!names.length) { container.innerHTML = '<div class="empty-state">Add customers first</div>'; return; }
    const existing = state.data.daily[date] || {};

    const field = (label, customer, fieldKey, val, cls='') =>
        `<div class="quick-field">
            <div class="quick-field-label">${label}</div>
            <input type="number" class="quick-input ${cls}"
                   data-customer="${customer}" data-field="${fieldKey}"
                   value="${val||''}" placeholder="0">
         </div>`;

    container.innerHTML = names.map(name => {
        const c = state.data.customers[name];
        const e = existing[name] || {};
        let fields = '';
        if ((c.shawarma_small_rate||0) > 0) fields += field('Small',  name, 'small',   e.shawarma_small_qty||'');
        if ((c.shawarma_large_rate||0) > 0) fields += field('Large',  name, 'large',   e.shawarma_large_qty||'');
        if ((c.burger_rate||0)         > 0) fields += field('Burger', name, 'burger',  e.burger_qty||'');
        if ((c.butter_rate||0)         > 0) fields += field('Butter', name, 'butter',  e.butter_qty||'');
        if ((c.mayo_rate||0)           > 0) fields += field('Mayo',   name, 'mayo',    e.mayo_qty||'');
                                            fields += field('Rent',   name, 'rent',    e.rent||'');
        if (state.role === 'owner')         fields += field('💵 Pay', name, 'payment', e.payment||'', 'payment');
        return `<div class="quick-card ${Object.keys(e).length?'has-data':''}">
                    <div class="quick-name">${name}</div>
                    <div class="quick-grid">${fields}</div>
                </div>`;
    }).join('');
}

function commitQuickEntries() {
    const date  = document.getElementById('quick-date').value;
    const daily = state.data.daily;
    const map   = {};
    document.querySelectorAll('.quick-input').forEach(inp => {
        const nm = inp.dataset.customer, f = inp.dataset.field;
        if (!map[nm]) map[nm] = {};
        map[nm][f] = parseFloat(inp.value) || 0;
    });
    if (!daily[date]) daily[date] = {};
    let saved = 0;
    for (const name of Object.keys(map)) {
        const d = map[name], c = state.data.customers[name];
        if (!c) continue;
        const qty = (d.small||0)+(d.large||0)+(d.burger||0)+(d.butter||0)+(d.mayo||0);
        if (!qty && !(d.payment||0) && !(d.rent||0)) { if (daily[date][name]) delete daily[date][name]; continue; }
        const sT=(d.small||0)*(c.shawarma_small_rate||0), lT=(d.large||0)*(c.shawarma_large_rate||0);
        const bT=(d.burger||0)*(c.burger_rate||0), bpT=(d.butter||0)*(c.butter_rate||0), mT=(d.mayo||0)*(c.mayo_rate||0);
        const dt=sT+lT+bT+bpT+mT+(d.rent||0);
        let pay = d.payment||0;
        if (state.role==='manager') pay = daily[date][name] ? (daily[date][name].payment||0) : 0;
        const po = getPrevOutstanding(name, date);
        daily[date][name] = {
            shawarma_small_qty:d.small||0, shawarma_small_rate:c.shawarma_small_rate||0, shawarma_small_total:sT,
            shawarma_large_qty:d.large||0, shawarma_large_rate:c.shawarma_large_rate||0, shawarma_large_total:lT,
            burger_qty:d.burger||0, burger_rate:c.burger_rate||0, burger_total:bT,
            butter_qty:d.butter||0, butter_rate:c.butter_rate||0, butter_total:bpT,
            mayo_qty:d.mayo||0, mayo_rate:c.mayo_rate||0, mayo_total:mT,
            rent:d.rent||0, day_total:dt, payment:pay, prev_outstanding:po, outstanding:po+dt-pay,
        };
        cascadeRecalc(name, date); saved++;
    }
    if (daily[date] && !Object.keys(daily[date]).length) delete daily[date];
    persistData();
    saved > 0 ? showStatus('quick-status', `✓ ${saved} entries saved`, 'success')
              : showStatus('quick-status', 'No data to save', 'warning');
    buildQuickList();
}

function switchEntryMode(mode) {
    const q = mode === 'quick';
    document.getElementById('mode-btn-quick').classList.toggle('active', q);
    document.getElementById('mode-btn-detailed').classList.toggle('active', !q);
    document.getElementById('entry-quick').style.display    = q ? 'block' : 'none';
    document.getElementById('entry-detailed').style.display = q ? 'none'  : 'block';
    if (q) buildQuickList();
}

function onDetailChange() {
    const name = v('detail-customer'), date = v('detail-date');
    if (name && date) {
        const e = state.data.daily[date]?.[name];
        if (e) {
            set('d-small',   e.shawarma_small_qty||'');
            set('d-large',   e.shawarma_large_qty||'');
            set('d-burger',  e.burger_qty||'');
            set('d-butter',  e.butter_qty||'');
            set('d-mayo',    e.mayo_qty||'');
            set('d-rent',    e.rent||'');
            if (state.role==='owner') set('d-payment', e.payment||'');
        } else {
            ['d-small','d-large','d-burger','d-butter','d-mayo','d-rent','d-payment'].forEach(id=>set(id,''));
        }
    }
    recalcPreview();
}

function recalcPreview() {
    const name = v('detail-customer'), date = v('detail-date');
    if (!name || !state.data.customers[name]) {
        ['p-small','p-large','p-burger','p-butter','p-mayo','p-rent','p-daytotal','p-prevout','p-newout']
            .forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='Rs 0';});
        return;
    }
    const c=state.data.customers[name];
    const sT=n('d-small')*(c.shawarma_small_rate||0), lT=n('d-large')*(c.shawarma_large_rate||0);
    const bT=n('d-burger')*(c.burger_rate||0), bpT=n('d-butter')*(c.butter_rate||0), mT=n('d-mayo')*(c.mayo_rate||0);
    const dt=sT+lT+bT+bpT+mT+n('d-rent'), po=getPrevOutstanding(name,date);
    const pay=state.role==='owner'?n('d-payment'):0, no=po+dt-pay;
    document.getElementById('p-small').textContent=fmtMoney(sT);
    document.getElementById('p-large').textContent=fmtMoney(lT);
    document.getElementById('p-burger').textContent=fmtMoney(bT);
    document.getElementById('p-butter').textContent=fmtMoney(bpT);
    document.getElementById('p-mayo').textContent=fmtMoney(mT);
    document.getElementById('p-rent').textContent=fmtMoney(n('d-rent'));
    document.getElementById('p-daytotal').textContent=fmtMoney(dt);
    const pe=document.getElementById('p-prevout'), ne=document.getElementById('p-newout');
    if(pe) pe.textContent=fmtMoney(po);
    if(ne){ne.textContent=fmtMoney(no);ne.className='stat-value '+(no<=0?'green':'gold');}
}

function commitDetailedEntry() {
    const name=v('detail-customer'), date=v('detail-date');
    if(!name||!state.data.customers[name]){showToast('Select a customer');return;}
    const c=state.data.customers[name];
    const sq=n('d-small'),lq=n('d-large'),bq=n('d-burger'),bpq=n('d-butter'),mq=n('d-mayo'),r=n('d-rent');
    const sT=sq*(c.shawarma_small_rate||0),lT=lq*(c.shawarma_large_rate||0);
    const bT=bq*(c.burger_rate||0),bpT=bpq*(c.butter_rate||0),mT=mq*(c.mayo_rate||0);
    const dt=sT+lT+bT+bpT+mT+r;
    let pay=0;
    if(state.role==='owner') pay=n('d-payment');
    else pay=state.data.daily[date]?.[name]?.payment||0;
    const po=getPrevOutstanding(name,date);
    if(!state.data.daily[date]) state.data.daily[date]={};
    state.data.daily[date][name]={
        shawarma_small_qty:sq,shawarma_small_rate:c.shawarma_small_rate||0,shawarma_small_total:sT,
        shawarma_large_qty:lq,shawarma_large_rate:c.shawarma_large_rate||0,shawarma_large_total:lT,
        burger_qty:bq,burger_rate:c.burger_rate||0,burger_total:bT,
