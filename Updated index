<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MA Bakers">
    <title>MA Bakers</title>
    <style>
        /* ============================================================
           RESET & ROOT VARIABLES
        ============================================================ */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        :root {
            --gold:          #C9A84C;
            --gold-light:    #E8C97A;
            --gold-dark:     #8B6914;
            --gold-glow:     rgba(201, 168, 76, 0.15);
            --gold-border:   rgba(201, 168, 76, 0.12);
            --gold-border-b: rgba(201, 168, 76, 0.30);
            --bg:            #0C0C0C;
            --card:          #161410;
            --card-alt:      #1C1A14;
            --text:          #F5F0E8;
            --text-muted:    #8A8070;
            --text-dim:      #5A5040;
            --green:         #4CAF82;
            --red:           #C94C4C;
            --nav-height:    70px;
        }

        /* ============================================================
           BASE
        ============================================================ */
        html, body {
            height: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================================
           SPLASH SCREEN
        ============================================================ */
        #splash {
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse at center, #1a1500 0%, #000 70%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        #splash-ring {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            border: 1px solid rgba(201,168,76,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transform: scale(0.5);
            transition: all 1s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 0 40px rgba(201,168,76,0.1), inset 0 0 40px rgba(201,168,76,0.05);
        }
        #splash-ring.show { opacity: 1; transform: scale(1); }

        #splash-logo {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid rgba(201,168,76,0.4);
        }

        #splash-title {
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 8px;
            text-transform: uppercase;
            color: var(--gold-light);
            opacity: 0;
            transform: translateY(15px);
            transition: all 0.8s ease 0.8s;
            margin-top: 28px;
        }
        #splash-title.show { opacity: 1; transform: translateY(0); }

        #splash-sub {
            font-size: 11px;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: var(--text-dim);
            opacity: 0;
            transition: opacity 0.8s ease 1.1s;
            margin-top: 8px;
        }
        #splash-sub.show { opacity: 1; }

        #splash-line {
            width: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin-top: 32px;
            transition: width 1.5s ease 1s;
        }
        #splash-line.show { width: 160px; }

        /* ============================================================
           LOGIN SCREEN
        ============================================================ */
        #login-screen {
            position: fixed;
            inset: 0;
            background: var(--bg);
            z-index: 9000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 30px;
        }
        #login-screen.hidden { display: none; }

        .login-logo {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid rgba(201,168,76,0.4);
            box-shadow: 0 0 30px rgba(201,168,76,0.2);
            margin-bottom: 24px;
        }

        .login-title {
            font-size: 26px;
            font-weight: 300;
            letter-spacing: 6px;
            text-transform: uppercase;
            color: var(--gold-light);
            margin-bottom: 8px;
        }

        .login-subtitle {
            font-size: 11px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-bottom: 40px;
        }

        .login-card {
            width: 100%;
            max-width: 360px;
            background: var(--card);
            border: 1px solid var(--gold-border-b);
            border-radius: 16px;
            padding: 28px 22px;
            position: relative;
            overflow: hidden;
        }
        .login-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

        .login-label {
            font-size: 10px;
            color: var(--text-dim);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 12px;
            text-align: center;
        }

        .login-input {
            width: 100%;
            background: rgba(0,0,0,0.4);
            border: 1px solid var(--gold-border);
            border-radius: 12px;
            padding: 16px;
            color: var(--gold-light);
            font-size: 24px;
            text-align: center;
            outline: none;
            letter-spacing: 12px;
            font-weight: 600;
            margin-bottom: 16px;
            transition: border-color 0.2s;
        }
        .login-input:focus { border-color: var(--gold-dark); }

        .login-error {
            color: var(--red);
            font-size: 12px;
            text-align: center;
            margin-top: 12px;
            display: none;
            letter-spacing: 1px;
        }
        .login-error.show { display: block; }

        /* ============================================================
           HEADER
        ============================================================ */
        .header {
            background: linear-gradient(180deg, rgba(20,18,12,0.98) 0%, rgba(12,12,12,0.95) 100%);
            padding: 48px 20px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--gold-border);
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(20px);
        }

        .header-logo {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid var(--gold-dark);
            box-shadow: 0 0 12px rgba(201,168,76,0.2);
            flex-shrink: 0;
        }

        .header-info { flex: 1; min-width: 0; }
        .header-title { font-size: 16px; font-weight: 600; letter-spacing: 1px; color: var(--gold-light); }
        .header-sub { font-size: 9px; color: var(--text-dim); letter-spacing: 3px; text-transform: uppercase; }
        .header-role { font-size: 9px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; margin-top: 2px; }

        .header-actions { display: flex; gap: 8px; flex-shrink: 0; }

        .btn-header {
            background: transparent;
            border: 1px solid var(--gold-border-b);
            color: var(--gold);
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-family: inherit;
            transition: all 0.2s;
        }
        .btn-header:active { opacity: 0.7; }

        /* ============================================================
           BOTTOM NAVIGATION
        ============================================================ */
        .bottom-nav {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            background: linear-gradient(180deg, rgba(12,12,12,0) 0%, rgba(10,10,8,0.99) 30%);
            border-top: 1px solid var(--gold-border);
            display: flex;
            padding: 10px 0 50px;
            z-index: 100;
            backdrop-filter: blur(30px);
        }

        .nav-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            padding: 4px 2px;
            border: none;
            background: none;
            position: relative;
        }
        .nav-item::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            transition: width 0.3s ease;
        }
        .nav-item.active::after { width: 30px; }

        .nav-icon {
            width: 20px;
            height: 20px;
            opacity: 0.25;
            color: var(--text);
            transition: all 0.3s ease;
            stroke: currentColor;
        }
        .nav-item.active .nav-icon { opacity: 1; color: var(--gold); }

        .nav-label {
            font-size: 9px;
            color: var(--text-dim);
            letter-spacing: 0.5px;
            text-transform: uppercase;
            font-weight: 500;
            transition: color 0.3s;
        }
        .nav-item.active .nav-label { color: var(--gold); }

        /* ============================================================
           PAGES
        ============================================================ */
        .page {
            display: none;
            padding: 16px;
            padding-bottom: 140px;
            min-height: 100vh;
        }
        .page.active { display: block; }

        .page-title {
            font-size: 22px;
            font-weight: 300;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text);
            margin-bottom: 4px;
        }

        .page-divider {
            width: 40px;
            height: 1px;
            background: linear-gradient(90deg, var(--gold), transparent);
            margin-bottom: 16px;
        }

        /* ============================================================
           CARDS
        ============================================================ */
        .card {
            background: var(--card);
            border: 1px solid var(--gold-border);
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 12px;
            position: relative;
            overflow: hidden;
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(201,168,76,0.3), transparent);
        }

        .card-premium {
            background: linear-gradient(135deg, #161410 0%, #1C1A10 100%);
            border: 1px solid var(--gold-border-b);
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 12px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 24px rgba(0,0,0,0.4);
        }
        .card-premium::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

        .card-label {
            font-size: 10px;
            font-weight: 600;
            color: var(--gold);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .card-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, var(--gold-border-b), transparent);
        }

        /* ============================================================
           FORM ELEMENTS
        ============================================================ */
        .form-group { margin-bottom: 12px; }

        .form-label {
            font-size: 10px;
            color: var(--text-dim);
            margin-bottom: 6px;
            display: block;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 500;
        }

        .form-input {
            width: 100%;
            background: rgba(0,0,0,0.4);
            border: 1px solid var(--gold-border);
            border-radius: 10px;
            padding: 12px 14px;
            color: var(--text);
            font-size: 15px;
            outline: none;
            transition: border-color 0.2s;
            font-family: inherit;
        }
        .form-input:focus { border-color: var(--gold-dark); }
        select.form-input { appearance: none; }

        /* ============================================================
           BUTTONS
        ============================================================ */
        .btn {
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            border: none;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 8px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-family: inherit;
            transition: transform 0.1s, opacity 0.1s;
        }
        .btn:active { transform: scale(0.98); opacity: 0.9; }

        .btn-primary {
            background: linear-gradient(135deg, #C9A84C 0%, #8B6914 50%, #C9A84C 100%);
            color: #0C0C0C;
            font-weight: 700;
            box-shadow: 0 4px 20px rgba(201,168,76,0.25);
        }

        .btn-outline {
            background: transparent;
            color: var(--gold);
            border: 1px solid var(--gold-border-b);
            font-weight: 500;
        }

        .btn-ghost {
            background: rgba(201,168,76,0.05);
            color: var(--text-muted);
            border: 1px solid var(--gold-border);
        }

        .btn-danger {
            background: rgba(201,76,76,0.08);
            color: var(--red);
            border: 1px solid rgba(201,76,76,0.2);
        }

        .icon-btn {
            background: rgba(201,168,76,0.06);
            border: 1px solid var(--gold-border);
            color: var(--gold);
            width: 34px;
            height: 34px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: opacity 0.1s;
        }
        .icon-btn:active { opacity: 0.7; }
        .icon-btn.danger { color: var(--red); border-color: rgba(201,76,76,0.2); }

        .btn-row { display: flex; gap: 6px; }

        .back-btn {
            background: transparent;
            border: 1px solid var(--gold-border);
            color: var(--gold);
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 14px;
            font-family: inherit;
        }

        /* ============================================================
           STAT GRID
        ============================================================ */
        .stat-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 12px;
        }

        .stat-cell {
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--gold-border);
            border-radius: 12px;
            padding: 12px;
            text-align: center;
        }
        .stat-cell.span2 { grid-column: span 2; }
        .stat-cell.accent {
            border-color: var(--gold-border-b);
            background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(0,0,0,0.3));
        }

        .stat-label {
            font-size: 9px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
            font-weight: 500;
        }

        .stat-value {
            font-size: 16px;
            font-weight: 600;
            color: var(--text);
        }
        .gold  { color: var(--gold-light) !important; }
        .green { color: var(--green) !important; }
        .red   { color: var(--red) !important; }

        /* ============================================================
           LIST ROWS
        ============================================================ */
        .list-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 0;
            border-bottom: 1px solid rgba(201,168,76,0.05);
        }
        .list-row:last-child { border-bottom: none; }

        .row-title { font-size: 14px; font-weight: 500; color: var(--text); }
        .row-sub   { font-size: 11px; color: var(--text-dim); margin-top: 3px; }

        /* ============================================================
           BADGES
        ============================================================ */
        .badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .badge-gold  { background: rgba(201,168,76,0.08); color: var(--gold-light); border: 1px solid rgba(201,168,76,0.2); }
        .badge-green { background: rgba(76,175,130,0.08); color: var(--green);      border: 1px solid rgba(76,175,130,0.2); }

        /* ============================================================
           DATE ROW
        ============================================================ */
        .date-row { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }

        .arrow-btn {
            background: rgba(0,0,0,0.4);
            border: 1px solid var(--gold-border);
            color: var(--gold);
            width: 42px;
            height: 42px;
            border-radius: 10px;
            font-size: 13px;
            cursor: pointer;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: inherit;
        }

        /* ============================================================
           HERO STAT
        ============================================================ */
        .hero {
            text-align: center;
            padding: 20px 16px;
        }
        .hero-label {
            font-size: 10px;
            color: var(--text-dim);
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        .hero-value {
            font-size: 32px;
            font-weight: 300;
            color: var(--gold-light);
            letter-spacing: 1px;
        }

        .gold-rule {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold-border-b), transparent);
            margin: 12px 0;
        }

        /* ============================================================
           TOAST NOTIFICATION
        ============================================================ */
        #toast {
            position: fixed;
            top: 95px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--card-alt);
            border: 1px solid var(--gold-border-b);
            color: var(--gold-light);
            padding: 10px 22px;
            border-radius: 24px;
            font-size: 12px;
            font-weight: 500;
            z-index: 9998;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
            white-space: nowrap;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        #toast.show { opacity: 1; }

        /* ============================================================
           STATUS BAR
        ============================================================ */
        .status-bar {
            text-align: center;
            padding: 12px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 10px;
            display: none;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .status-bar.show { display: block; }
        .status-bar.success { background: rgba(76,175,130,0.08); color: var(--green); border: 1px solid rgba(76,175,130,0.15); }
        .status-bar.warning { background: rgba(201,168,76,0.08); color: var(--gold);  border: 1px solid rgba(201,168,76,0.15); }

        /* ============================================================
           MODE TOGGLE
        ============================================================ */
        .mode-toggle {
            display: flex;
            background: var(--card);
            border: 1px solid var(--gold-border);
            border-radius: 12px;
            padding: 4px;
            margin-bottom: 14px;
        }

        .mode-btn {
            flex: 1;
            padding: 11px;
            background: transparent;
            color: var(--text-dim);
            border: none;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        .mode-btn.active {
            background: linear-gradient(135deg, #C9A84C, #8B6914);
            color: #0C0C0C;
            box-shadow: 0 2px 12px rgba(201,168,76,0.3);
        }

        /* ============================================================
           QUICK ENTRY
        ============================================================ */
        .quick-card {
            background: var(--card);
            border: 1px solid var(--gold-border);
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 10px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s, background 0.2s;
        }
        .quick-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(201,168,76,0.2), transparent);
        }
        .quick-card.has-data {
            border-color: var(--gold-border-b);
            background: linear-gradient(135deg, #161410, #1C1A10);
        }

        .quick-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--gold-light);
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }

        .quick-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
        }

        .quick-field { display: flex; flex-direction: column; gap: 3px; }

        .quick-field-label {
            font-size: 8px;
            color: var(--text-dim);
            letter-spacing: 0.5px;
            text-transform: uppercase;
            font-weight: 500;
        }

        .quick-input {
            background: rgba(0,0,0,0.4);
            border: 1px solid var(--gold-border);
            border-radius: 8px;
            padding: 8px 6px;
            color: var(--text);
            font-size: 14px;
            text-align: center;
            outline: none;
            font-family: inherit;
            -moz-appearance: textfield;
            transition: border-color 0.2s;
        }
        .quick-input::-webkit-outer-spin-button,
        .quick-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .quick-input:focus { border-color: var(--gold-dark); }
        .quick-input.payment { color: var(--green); }

        /* ============================================================
           CUSTOMER HISTORY
        ============================================================ */
        .history-entry {
            background: var(--card);
            border: 1px solid var(--gold-border);
            border-radius: 12px;
            padding: 14px;
            margin-bottom: 10px;
        }

        .history-date {
            font-size: 11px;
            color: var(--gold);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }

        /* ============================================================
           BILL OVERLAY
        ============================================================ */
        #bill-overlay {
            position: fixed;
            inset: 0;
            background: white;
            z-index: 9999;
            overflow-y: auto;
            display: none;
        }
        #bill-overlay.show { display: block; }

        .bill-topbar {
            position: sticky;
            top: 0;
            background: #1a1a00;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--gold);
            z-index: 10;
        }

        .bill-body { padding: 20px; max-width: 600px; margin: 0 auto; font-family: monospace; color: black; }

        .bill-header-section {
            text-align: center;
            border-bottom: 2px solid black;
            padding-bottom: 12px;
            margin-bottom: 12px;
        }

        .bill-company { font-size: 20px; font-weight: bold; letter-spacing: 4px; }
        .bill-company-sub { font-size: 12px; letter-spacing: 2px; margin-top: 4px; }

        .bill-meta {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
