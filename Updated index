function renderOutstanding() {
    const daily    = state.data.daily;
    const listEl   = document.getElementById('outstanding-list');
    const items    = [];

    for (const name of Object.keys(state.data.customers)) {
        const entrDates = Object.keys(daily).filter(d => daily[d][name]).sort();
        let amount = 0;
        let label  = 'No entries yet';

        if (entrDates.length) {
            amount = daily[entrDates[entrDates.length - 1]][name].outstanding || 0;
            label  = entrDates[entrDates.length - 1];
        } else {
            amount = state.data.customers[name].opening_outstanding || 0;
        }

        if (amount > 0) items.push({ name, label, amount });
    }

    if (!items.length) {
        listEl.innerHTML = '<div class="all-clear">✓ All Accounts Clear</div>';
        return;
    }

    // Sort by amount descending
    items.sort((a, b) => b.amount - a.amount);

    listEl.innerHTML = items.map(i =>
        `<div class="list-row">
             <div>
                 <div class="row-title">${i.name}</div>
                 <div class="row-sub">${i.label}</div>
             </div>
             <span class="badge badge-gold">${fmtMoney(i.amount)}</span>
         </div>`
    ).join('');
}

