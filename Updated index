/* ================================================================
   MONTHLY REPORT
================================================================ */
function renderMonthlyReport() {
    const year    = document.getElementById('mon-year').value;
    const month   = document.getElementById('mon-month').value;
    const prefix  = `${year}-${month}`;
    const daily   = state.data.daily;
    const content = document.getElementById('monthly-content');

    const monthDates = Object.keys(daily).filter(d => d.startsWith(prefix)).sort();
    if (!monthDates.length) {
        showToast('No data for this month');
        content.innerHTML = '';
        return;
    }

    const totals = {};

    for (const d of monthDates) {
        for (const [name, e] of Object.entries(daily[d])) {
            if (!totals[name]) totals[name] = { small:0, large:0, burger:0, butter:0, mayo:0, rent:0, paid:0 };
            totals[name].small  += e.shawarma_small_total  || 0;
            totals[name].large  += e.shawarma_large_total  || 0;
            totals[name].burger += e.burger_total          || 0;
            totals[name].butter += e.butter_total          || 0;
            totals[name].mayo   += e.mayo_total            || 0;
            totals[name].rent   += e.rent                  || 0;
            totals[name].paid   += e.payment               || 0;
        }
    }

    let grand = { total:0, paid:0, out:0 };

    const rows = Object.entries(totals).map(([name, t]) => {
        const custTotal = t.small + t.large + t.burger + t.butter + t.mayo + t.rent;
        grand.total += custTotal;
        grand.paid  += t.paid;

        // Latest outstanding for this customer in this month
        const lastMonthDate = monthDates.filter(d => daily[d][name]).sort().pop();
        const out = lastMonthDate ? (daily[lastMonthDate][name].outstanding || 0) : 0;
        if (out > 0) grand.out += out;

        const badge = state.role === 'owner'
            ? `<span class="badge ${out <= 0 ? 'badge-green' : 'badge-gold'}">${out <= 0 ? 'Paid' : fmtMoney(out)}</span>`
            : '';

        return `<div class="list-row">
                    <div>
                        <div class="row-title">${name}</div>
                        <div class="row-sub">Total: ${fmtMoney(custTotal)}</div>
                        <div class="row-sub">Rent: ${fmtMoney(t.rent)}</div>
                    </div>
                    ${badge}
                </div>`;
    }).join('');

    const ownerStats = state.role === 'owner'
        ? `<div class="stat-cell"><div class="stat-label">Paid</div><div class="stat-value green">${fmtMoney(grand.paid)}</div></div>
           <div class="stat-cell accent span2"><div class="stat-label">Total Outstanding</div><div class="stat-value gold">${fmtMoney(grand.out)}</div></div>`
        : '';

    content.innerHTML = `
        <div class="card-premium">
            <div class="hero">
                <div class="hero-label">Monthly Revenue</div>
                <div class="hero-value">${fmtMoney(grand.total)}</div>
            </div>
            <div class="gold-rule"></div>
            <div class="stat-grid">
                ${ownerStats}
            </div>
        </div>
        <div class="card">${rows}</div>`;
}

