function recalcPreview() {
    const name = v('detail-customer');
    const date = v('detail-date');

    if (!name || !state.data.customers[name]) {
        ['p-small','p-large','p-burger','p-butter','p-mayo','p-rent','p-daytotal','p-prevout','p-newout']
            .forEach(id => { const el = document.getElementById(id); if (el) el.textContent = 'Rs 0'; });
        return;
    }

    const c = state.data.customers[name];

    const smallT  = n('d-small')  * (c.shawarma_small_rate || 0);
    const largeT  = n('d-large')  * (c.shawarma_large_rate || 0);
    const burgerT = n('d-burger') * (c.burger_rate          || 0);
    const butterT = n('d-butter') * (c.butter_rate          || 0);
    const mayoT   = n('d-mayo')   * (c.mayo_rate            || 0);
    const rentT   = n('d-rent');
    const dayTotal = smallT + largeT + burgerT + butterT + mayoT + rentT;
    const prevOut  = getPrevOutstanding(name, date);
    const payment  = state.role === 'owner' ? n('d-payment') : 0;
    const newOut   = prevOut + dayTotal - payment;

    document.getElementById('p-small').textContent   = fmtMoney(smallT);
    document.getElementById('p-large').textContent   = fmtMoney(largeT);
    document.getElementById('p-burger').textContent  = fmtMoney(burgerT);
    document.getElementById('p-butter').textContent  = fmtMoney(butterT);
    document.getElementById('p-mayo').textContent    = fmtMoney(mayoT);
    document.getElementById('p-rent').textContent    = fmtMoney(rentT);
    document.getElementById('p-daytotal').textContent = fmtMoney(dayTotal);

    const prevEl = document.getElementById('p-prevout');
    const newEl  = document.getElementById('p-newout');
    if (prevEl) prevEl.textContent = fmtMoney(prevOut);
    if (newEl) {
        newEl.textContent = fmtMoney(newOut);
        newEl.className   = 'stat-value ' + (newOut <= 0 ? 'green' : 'gold');
    }
}

function commitDetailedEntry() {
    const name = v('detail-customer');
    const date = v('detail-date');

    if (!name || !state.data.customers[name]) {
        showToast('Please select a customer');
        return;
    }

    const c = state.data.customers[name];

    const smallQty  = n('d-small');
    const largeQty  = n('d-large');
    const burgerQty = n('d-burger');
    const butterQty = n('d-butter');
    const mayoQty   = n('d-mayo');
    const rent      = n('d-rent');

    const smallT  = smallQty  * (c.shawarma_small_rate || 0);
    const largeT  = largeQty  * (c.shawarma_large_rate || 0);
    const burgerT = burgerQty * (c.burger_rate          || 0);
    const butterT = butterQty * (c.butter_rate          || 0);
    const mayoT   = mayoQty   * (c.mayo_rate            || 0);
    const dayTotal = smallT + largeT + burgerT + butterT + mayoT + rent;

    // Payment handling
    let payment = 0;
    if (state.role === 'owner') {
        payment = n('d-payment');
    } else {
        // Manager: preserve existing payment
        payment = state.data.daily[date]?.[name]?.payment || 0;
    }

    const prevOut = getPrevOutstanding(name, date);

    if (!state.data.daily[date]) state.data.daily[date] = {};

    state.data.daily[date][name] = {
        shawarma_small_qty:   smallQty,
        shawarma_small_rate:  c.shawarma_small_rate || 0,
        shawarma_small_total: smallT,
        shawarma_large_qty:   largeQty,
        shawarma_large_rate:  c.shawarma_large_rate || 0,
        shawarma_large_total: largeT,
        burger_qty:           burgerQty,
        burger_rate:          c.burger_rate  || 0,
        burger_total:         burgerT,
        butter_qty:           butterQty,
        butter_rate:          c.butter_rate  || 0,
        butter_total:         butterT,
        mayo_qty:             mayoQty,
        mayo_rate:            c.mayo_rate    || 0,
        mayo_total:           mayoT,
        rent,
        day_total:        dayTotal,
        payment,
        prev_outstanding: prevOut,
        outstanding:      prevOut + dayTotal - payment,
    };

    cascadeRecalc(name, date);
    persistData();

    if (state.role === 'owner') {
        const newOut = prevOut + dayTotal - payment;
        showStatus('detail-status',
            `Saved · Outstanding ${fmtMoney(newOut)}`,
            newOut <= 0 ? 'success' : 'warning');
    } else {
        showStatus('detail-status', 'Entry saved successfully', 'success');
    }

    // Clear fields
    ['d-small','d-large','d-burger','d-butter','d-mayo','d-rent','d-payment']
        .forEach(id => set(id, ''));
    recalcPreview();
}

