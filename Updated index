================================================================ */
loadData();
initDates();
renderCustomerList();
renderOutstanding();

// Enter key on login
document.getElementById('login-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') handleLogin();
});

// Run splash last
initSplash();
