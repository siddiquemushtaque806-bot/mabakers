function generateBill(name, from, to) {
    const daily=state.data.daily;
    const dates=Object.keys(daily).filter(d=>daily[d][name]!==undefined&&d>=from&&d<=to).sort();
    if(!dates.length){showToast('No entries');return;}
    state.currentBillName=name; state.currentBillFrom=from; state.currentBillTo=to;
    const cols={
        small: dates.some(d=>(daily[d][name].shawarma_small_qty||0)>0),
        large: dates.some(d=>(daily[d][name].shawarma_large_qty||0)>0),
        burger:dates.some(d=>(daily[d][name].burger_qty||0)>0),
        butter:dates.some(d=>(daily[d][name].butter_qty||0)>0),
        mayo:  dates.some(d=>(daily[d][name].mayo_qty||0)>0),
        rent:  dates.some(d=>(daily[d][name].rent||0)>0),
    };
    const thStyle='padding:9px 6px;background:#1a0e00;color:#E8C97A;font-size:10px;letter-spacing:1px;border:1px solid #3a2800;';
    let th=`<th style="${thStyle}text-align:left;">DATE</th>`;
    if(cols.small)  th+=`<th style="${thStyle}text-align:center;">SMALL</th>`;
    if(cols.large)  th+=`<th style="${thStyle}text-align:center;">LARGE</th>`;
    if(cols.burger) th+=`<th style="${thStyle}text-align:center;">BURGER</th>`;
    if(cols.butter) th+=`<th style="${thStyle}text-align:center;">BUTTER</th>`;
    if(cols.mayo)   th+=`<th style="${thStyle}text-align:center;">MAYO</th>`;
    if(cols.rent)   th+=`<th style="${thStyle}text-align:center;">RENT</th>`;
    th+=`<th style="${thStyle}text-align:right;">TOTAL</th>`;
    let totals={s:0,l:0,b:0,bp:0,m:0,rent:0,grand:0}, tbody='', ri=0;
    dates.forEach(d=>{
        const e=daily[d][name], bg=ri++%2===0?'#fffdf5':'#fff8e8';
        const tdS=`padding:8px;border:1px solid #e8d5a0;background:${bg};font-size:11px;`;
        let td=`<td style="${tdS}font-weight:600;color:#2a1a00;">${d}</td>`;
        if(cols.small)  {td+=`<td style="${tdS}text-align:center;color:#1a0e00;">${e.shawarma_small_qty||''}</td>`;  totals.s+=e.shawarma_small_qty||0;}
        if(cols.large)  {td+=`<td style="${tdS}text-align:center;color:#1a0e00;">${e.shawarma_large_qty||''}</td>`;  totals.l+=e.shawarma_large_qty||0;}
        if(cols.burger) {td+=`<td style="${tdS}text-align:center;color:#1a0e00;">${e.burger_qty||''}</td>`;           totals.b+=e.burger_qty||0;}
        if(cols.butter) {td+=`<td style="${tdS}text-align:center;color:#1a0e00;">${e.butter_qty||''}</td>`;           totals.bp+=e.butter_qty||0;}
        if(cols.mayo)   {td+=`<td style="${tdS}text-align:center;color:#1a0e00;">${e.mayo_qty||''}</td>`;             totals.m+=e.mayo_qty||0;}
        if(cols.rent)   {td+=`<td style="${tdS}text-align:center;color:#1a0e00;">${e.rent?Math.round(e.rent):''}</td>`;totals.rent+=e.rent||0;}
        td+=`<td style="${tdS}text-align:right;font-weight:700;color:#8B6914;">${Math.round(e.day_total||0).toLocaleString('en-PK')}</td>`;
        totals.grand+=e.day_total||0; tbody+=`<tr>${td}</tr>`;
    });
    let sumRows='';
    if(cols.small)  sumRows+=`<tr><td style="padding:7px 12px;border:1px solid #e8d5a0;color:#2a1a00;font-size:11px;">Shawarma Small</td><td style="padding:7px 12px;border:1px solid #e8d5a0;text-align:right;font-size:11px;">${totals.s} pcs</td></tr>`;
    if(cols.large)  sumRows+=`<tr><td style="padding:7px 12px;border:1px solid #e8d5a0;color:#2a1a00;font-size:11px;">Shawarma Large</td><td style="padding:7px 12px;border:1px solid #e8d5a0;text-align:right;font-size:11px;">${totals.l} pcs</td></tr>`;
    if(cols.burger) sumRows+=`<tr><td style="padding:7px 12px;border:1px solid #e8d5a0;color:#2a1a00;font-size:11px;">Burger</td><td style="padding:7px 12px;border:1px solid #e8d5a0;text-align:right;font-size:11px;">${totals.b} pcs</td></tr>`;
    if(cols.butter) sumRows+=`<tr><td style="padding:7px 12px;border:1px solid #e8d5a0;color:#2a1a00;font-size:11px;">Butter Paper</td><td style="padding:7px 12px;border:1px solid #e8d5a0;text-align:right;font-size:11px;">${totals.bp} pcs</td></tr>`;
    if(cols.mayo)   sumRows+=`<tr><td style="padding:7px 12px;border:1px solid #e8d5a0;color:#2a1a00;font-size:11px;">Mayonnaise</td><td style="padding:7px 12px;border:1px solid #e8d5a0;text-align:right;font-size:11px;">${totals.m} pcs</td></tr>`;
    if(cols.rent)   sumRows+=`<tr><td style="padding:7px 12px;border:1px solid #e8d5a0;color:#2a1a00;font-size:11px;">Total Rent</td><td style="padding:7px 12px;border:1px solid #e8d5a0;text-align:right;font-size:11px;">Rs ${Math.round(totals.rent).toLocaleString('en-PK')}</td></tr>`;
    const latestEntry=daily[dates[dates.length-1]][name];
    const outstanding=latestEntry.outstanding||0;
    const outRows=state.role==='owner'?`
        <tr style="background:#f0fff8;"><td style="padding:8px 12px;border:1px solid #c8e8d8;color:#1a5a35;font-size:11px;">Total Paid</td>
            <td style="padding:8px 12px;border:1px solid #c8e8d8;text-align:right;color:#1a5a35;font-weight:700;font-size:11px;">Rs ${Math.round(latestEntry.payment||0).toLocaleString('en-PK')}</td></tr>
        <tr style="background:${outstanding<=0?'#e8fff4':'#fff3e8'};"><td style="padding:10px 12px;border:2px solid ${outstanding<=0?'#4CAF82':'#C9A84C'};font-weight:800;font-size:13px;color:#1a0e00;">OUTSTANDING</td>
            <td style="padding:10px 12px;border:2px solid ${outstanding<=0?'#4CAF82':'#C9A84C'};text-align:right;font-weight:800;font-size:13px;color:${outstanding<=0?'#1a5a35':'#8B6914'};">${outstanding<=0?'✓ PAID':'Rs '+Math.round(outstanding).toLocaleString('en-PK')}</td></tr>`:'';
    const billHTML=`<div id="bill-content" style="background:#fffdf5;max-width:580px;margin:0 auto;font-family:Georgia,serif;">
        <div style="height:6px;background:linear-gradient(90deg,#8B6914,#C9A84C,#E8C97A,#C9A84C,#8B6914);"></div>
        <div style="text-align:center;padding:24px 20px 18px;background:linear-gradient(180deg,#1a0e00 0%,#2d1a00 100%);">
            <div style="font-size:10px;letter-spacing:8px;color:#C9A84C;margin-bottom:10px;">✦ &nbsp; ✦ &nbsp; ✦</div>
            <div style="font-size:30px;font-weight:900;letter-spacing:8px;color:#F5E6C0;text-transform:uppercase;">M.A BAKERS</div>
            <div style="width:60px;height:2px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);margin:10px auto;"></div>
            <div style="font-size:12px;letter-spacing:6px;color:#C9A84C;text-transform:uppercase;">S H A W A R M A</div>
            <div style="font-size:10px;letter-spacing:8px;color:#8B6914;margin-top:10px;">✦ &nbsp; ✦ &nbsp; ✦</div>
        </div>
        <div style="height:3px;background:linear-gradient(90deg,#8B6914,#E8C97A,#8B6914);"></div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;background:#fff8e8;border-bottom:1px solid #e8d5a0;">
            <div><div style="font-size:9px;color:#8B6914;letter-spacing:2px;text-transform:uppercase;margin-bottom:3px;">Bill To</div>
                <div style="font-size:18px;font-weight:800;color:#1a0e00;">${name}</div></div>
            <div style="text-align:right;"><div style="font-size:9px;color:#8B6914;letter-spacing:2px;text-transform:uppercase;margin-bottom:3px;">Issued</div>
                <div style="font-size:12px;font-weight:600;color:#1a0e00;">${new Date().toLocaleDateString('en-PK')}</div></div>
        </div>
        <div style="background:linear-gradient(135deg,#C9A84C,#8B6914);padding:8px 20px;text-align:center;">
            <span style="font-size:11px;color:white;letter-spacing:3px;font-weight:700;text-transform:uppercase;">PERIOD &nbsp;·&nbsp; ${from} &nbsp;→&nbsp; ${to}</span>
        </div>
        <div style="padding:16px 20px 8px;">
            <table style="width:100%;border-collapse:collapse;"><thead><tr>${th}</tr></thead><tbody>${tbody}</tbody></table>
        </div>
        <div style="padding:0 20px 16px;"><div style="border:1px solid #C9A84C;border-radius:6px;overflow:hidden;">
            <div style="background:linear-gradient(135deg,#2d1a00,#1a0e00);padding:9px 12px;">
                <span style="color:#E8C97A;font-size:10px;letter-spacing:3px;font-weight:700;text-transform:uppercase;">📋 SUMMARY</span>
            </div>
            <table style="width:100%;border-collapse:collapse;">${sumRows}
                <tr style="background:#fff3d0;"><td style="padding:10px 12px;border-top:2px solid #C9A84C;font-weight:800;font-size:13px;color:#1a0e00;">Total Amount</td>
                    <td style="padding:10px 12px;border-top:2px solid #C9A84C;text-align:right;font-weight:800;font-size:14px;color:#8B6914;">Rs ${Math.round(totals.grand).toLocaleString('en-PK')}</td></tr>
                ${outRows}
            </table>
        </div></div>
        <div style="padding:16px 20px;border-top:1px solid #e8d5a0;background:#fffdf5;display:flex;justify-content:space-between;align-items:flex-end;">
            <div style="font-size:9px;color:#8B6914;line-height:1.8;">
                <div>Generated: ${new Date().toLocaleDateString('en-PK')}</div>
                <div style="font-weight:600;">M.A Bakers — Shawarma</div>
            </div>
            <div style="text-align:center;"><div style="width:130px;border-top:1.5px solid #2a1a00;padding-top:4px;font-size:9px;color:#8B6914;letter-spacing:1px;text-transform:uppercase;">Authorised Signature</div></div>
        </div>
        <div style="height:6px;background:linear-gradient(90deg,#8B6914,#C9A84C,#E8C97A,#C9A84C,#8B6914);"></div>
    </div>`;
    document.getElementById('bill-body').innerHTML=billHTML;
    document.getElementById('bill-overlay').classList.add('show');
}

function closeBill() { document.getElementById('bill-overlay').classList.remove('show'); }

function copyBillText() {
    const text=buildBillText(state.currentBillName,state.currentBillFrom,state.currentBillTo);
    copyText(text);
}

function saveAsImage() {
    if(window.AndroidBridge && window.AndroidBridge.captureAndSave) {
        showToast('Capturing bill...');
        const name=state.currentBillName||'Bill';
        window.AndroidBridge.captureAndSave('MABakers_'+name+'_'+Date.now()+'.jpg');
    } else {
        showToast('Not supported on this device');
    }
}

function buildBillText(name,from,to) {
    const daily=state.data.daily;
    const dates=Object.keys(daily).filter(d=>daily[d][name]!==undefined&&d>=from&&d<=to).sort();
    let text=`*M.A BAKERS — SHAWARMA*\nM/s: ${name}\nPeriod: ${from} to ${to}\n─────────────────────\n`;
    let grand=0;
    dates.forEach(d=>{
        const e=daily[d][name];
        let line=`${d}: `;
        if(e.shawarma_small_qty) line+=`Small ${e.shawarma_small_qty} `;
        if(e.shawarma_large_qty) line+=`Large ${e.shawarma_large_qty} `;
        if(e.burger_qty)         line+=`Burger ${e.burger_qty} `;
        if(e.butter_qty)         line+=`Butter ${e.butter_qty} `;
        if(e.mayo_qty)           line+=`Mayo ${e.mayo_qty} `;
        if(e.rent)               line+=`Rent Rs${Math.round(e.rent)} `;
        line+=`= *Rs ${Math.round(e.day_total||0).toLocaleString('en-PK')}*`;
        text+=line+'\n'; grand+=e.day_total||0;
    });
    text+=`─────────────────────\n*Total: Rs ${Math.round(grand).toLocaleString('en-PK')}*\n`;
    if(state.role==='owner'){
        const out=daily[dates[dates.length-1]]?.[name]?.outstanding||0;
        text+=`*Outstanding: ${out<=0?'PAID ✓':'Rs '+Math.round(out).toLocaleString('en-PK')}*\n`;
    }
    return text;
}

function copyText(text) {
    const el=document.createElement('textarea');
    el.value=text; el.style.cssText='position:fixed;opacity:0;top:0;left:0;';
    document.body.appendChild(el); el.select();
    try{document.execCommand('copy');showToast('✓ Copied — paste in WhatsApp');}
    catch(_){showToast('Could not copy');}
    document.body.removeChild(el);
}

function initDates() {
    const t=todayISO(), now=new Date();
    set('quick-date',t); set('detail-date',t); set('sum-date',t); set('hist-date',t);
    set('ch-from',firstOfMonth()); set('ch-to',t); set('pay-date',t);
    set('mon-year',now.getFullYear());
    set('mon-month',String(now.getMonth()+1).padStart(2,'0'));
}

function initSplash() {
    setTimeout(()=>{
        document.getElementById('splash-ring').classList.add('show');
        document.getElementById('splash-title').classList.add('show');
        document.getElementById('splash-sub').classList.add('show');
        document.getElementById('splash-line').classList.add('show');
    },100);
    setTimeout(()=>{
        const splash=document.getElementById('splash');
        splash.style.transition='opacity 0.8s ease';
        splash.style.opacity='0';
        setTimeout(()=>{
            splash.remove();
            const saved=localStorage.getItem('ma_role');
            if(saved && Object.values(PASSWORDS).includes(saved)){
                state.role=saved; applyRole(); startAutoSync(); buildQuickList();
            } else {
                document.getElementById('login-screen').classList.remove('hidden');
            }
        },800);
    },3000);
}

/* Bootstrap */
loadData();
initDates();
renderCustomerList();
renderOutstanding();
document.getElementById('login-input').addEventListener('keydown', e=>{if(e.key==='Enter') handleLogin();});
initSplash();
</script>
</body>
</html>
