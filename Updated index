function buildQuickList() {
    const date       = document.getElementById('quick-date').value;
    const container  = document.getElementById('quick-list');
    const customers  = state.data.customers;
    const names      = Object.keys(customers);

    if (!names.length) {
        container.innerHTML = '<div class="empty-state">Add customers first</div>';
        return;
    }

    const existing = state.data.daily[date] || {};

    container.innerHTML = names.map(name => {
        const c = customers[name];
        const e = existing[name] || {};

        const hasSmall  = (c.shawarma_small_rate || 0) > 0;
        const hasLarge  = (c.shawarma_large_rate  || 0) > 0;
        const hasBurger = (c.burger_rate           || 0) > 0;
        const hasButter = (c.butter_rate           || 0) > 0;
        const hasMayo   = (c.mayo_rate             || 0) > 0;

        const field = (label, fieldKey, val, extra = '') =>
            `<div class="quick-field">
                <div class="quick-field-label">${label}</div>
                <input type="number" class="quick-input ${extra}"
                       data-customer="${name}" data-field="${fieldKey}"
                       value="${val || ''}" placeholder="0">
             </div>`;

        let fields = '';
        if (hasSmall)  fields += field('Small',   'small',   e.shawarma_small_qty  || 0 || '');
        if (hasLarge)  fields += field('Large',   'large',   e.shawarma_large_qty  || 0 || '');
        if (hasBurger) fields += field('Burger',  'burger',  e.burger_qty          || 0 || '');
        if (hasButter) fields += field('Butter',  'butter',  e.butter_qty          || 0 || '');
        if (hasMayo)   fields += field('Mayo',    'mayo',    e.mayo_qty            || 0 || '');
                       fields += field('Rent',    'rent',    e.rent                || 0 || '');

        if (state.role === 'owner') {
            fields += field('💵 Payment', 'payment', e.payment || 0 || '', 'payment');
        }

        const hasData = Object.keys(e).length > 0;

        return `<div class="quick-card ${hasData ? 'has-data' : ''}">
                    <div class="quick-name">${name}</div>
                    <div class="quick-grid">${fields}</div>
                </div>`;
    }).join('');
}

function commitQuickEntries() {
    const date    = document.getElementById('quick-date').value;
    const inputs  = document.querySelectorAll('.quick-input');
    const daily   = state.data.daily;

    // Group input values by customer
    const byCustomer = {};
    inputs.forEach(input => {
        const name  = input.dataset.customer;
        const field = input.dataset.field;
        const val   = parseFloat(input.value) || 0;
        if (!byCustomer[name]) byCustomer[name] = {};
        byCustomer[name][field] = val;
    });

    // Ensure date bucket exists
    if (!daily[date]) daily[date] = {};

    let savedCount = 0;

    for (const name of Object.keys(byCustomer)) {
        const d = byCustomer[name];
        const c = state.data.customers[name];
        if (!c) continue;

        const totalQty = (d.small || 0) + (d.large || 0) + (d.burger || 0)
                       + (d.butter || 0) + (d.mayo || 0);
        const hasData  = totalQty > 0 || (d.payment || 0) > 0 || (d.rent || 0) > 0;

        if (!hasData) {
            // Remove entry if it existed
            if (daily[date][name]) delete daily[date][name];
            continue;
        }

        // Rates
        const rates = {
            small:  c.shawarma_small_rate || 0,
            large:  c.shawarma_large_rate || 0,
            burger: c.burger_rate         || 0,
            butter: c.butter_rate         || 0,
            mayo:   c.mayo_rate           || 0,
        };

        // Totals
        const smallTotal  = (d.small  || 0) * rates.small;
        const largeTotal  = (d.large  || 0) * rates.large;
        const burgerTotal = (d.burger || 0) * rates.burger;
        const butterTotal = (d.butter || 0) * rates.butter;
        const mayoTotal   = (d.mayo   || 0) * rates.mayo;
        const dayTotal    = smallTotal + largeTotal + burgerTotal + butterTotal + mayoTotal + (d.rent || 0);

        // Payment: managers cannot change payment
        let payment = d.payment || 0;
        if (state.role === 'manager') {
            payment = daily[date][name] ? (daily[date][name].payment || 0) : 0;
        }

        const prevOut = getPrevOutstanding(name, date);

        daily[date][name] = {
            shawarma_small_qty:   d.small  || 0,
            shawarma_small_rate:  rates.small,
            shawarma_small_total: smallTotal,
            shawarma_large_qty:   d.large  || 0,
            shawarma_large_rate:  rates.large,
            shawarma_large_total: largeTotal,
            burger_qty:           d.burger || 0,
            burger_rate:          rates.burger,
            burger_total:         burgerTotal,
            butter_qty:           d.butter || 0,
            butter_rate:          rates.butter,
            butter_total:         butterTotal,
            mayo_qty:             d.mayo   || 0,
            mayo_rate:            rates.mayo,
            mayo_total:           mayoTotal,
            rent:                 d.rent   || 0,
            day_total:            dayTotal,
            payment:              payment,
            prev_outstanding:     prevOut,
            outstanding:          prevOut + dayTotal - payment,
        };

        // Cascade recalculate future dates for this customer
        cascadeRecalc(name, date);
        savedCount++;
    }

    // Clean up empty date bucket
    if (daily[date] && Object.keys(daily[date]).length === 0) {
        delete daily[date];
    }

    persistData();

    if (savedCount > 0) {
        showStatus('quick-status', `✓ ${savedCount} ${savedCount === 1 ? 'entry' : 'entries'} saved`, 'success');
        buildQuickList(); // refresh to show has-data styling
    } else {
        showStatus('quick-status', 'No data to save', 'warning');
    }
}

