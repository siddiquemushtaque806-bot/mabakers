function commitPayments() {
    const date=document.getElementById('pay-date').value;
    const daily=state.data.daily;
    if(!daily[date]) daily[date]={};
    let saved=0;
    document.querySelectorAll('#payment-list .quick-input').forEach(inp=>{
        const name=inp.dataset.customer, pay=parseFloat(inp.value)||0;
        const c=state.data.customers[name]; if(!c) return;
        if(daily[date][name]){
            daily[date][name].payment=pay;
            daily[date][name].outstanding=daily[date][name].prev_outstanding+daily[date][name].day_total-pay;
        } else {
            if(!pay) return;
            const po=getPrevOutstanding(name,date);
            daily[date][name]={
                shawarma_small_qty:0,shawarma_small_rate:c.shawarma_small_rate||0,shawarma_small_total:0,
                shawarma_large_qty:0,shawarma_large_rate:c.shawarma_large_rate||0,shawarma_large_total:0,
                burger_qty:0,burger_rate:c.burger_rate||0,burger_total:0,
                butter_qty:0,butter_rate:c.butter_rate||0,butter_total:0,
                mayo_qty:0,mayo_rate:c.mayo_rate||0,mayo_total:0,
                rent:0,day_total:0,payment:pay,prev_outstanding:po,outstanding:po-pay,
            };
        }
        cascadeRecalc(name,date); saved++;
    });
    if(daily[date]&&!Object.keys(daily[date]).length) delete daily[date];
    persistData();
    saved>0?showStatus('payment-status',`✓ ${saved} payments saved`,'success')
           :showStatus('payment-status','No payments entered','warning');
    buildPaymentList(); renderOutstanding();
}

function renderOutstanding() {
    const daily=state.data.daily, listEl=document.getElementById('outstanding-list'), items=[];
