function saveCustomer() {
    const newName=v('cf-name');
    const sr=parseFloat(document.getElementById('cf-small').value)||0;
    const lr=parseFloat(document.getElementById('cf-large').value)||0;
    const br=parseFloat(document.getElementById('cf-burger').value)||0;
    const bpr=parseFloat(document.getElementById('cf-butter').value)||0;
    const mr=parseFloat(document.getElementById('cf-mayo').value)||0;
    const op=parseFloat(document.getElementById('cf-opening').value)||0;
    if(!newName){showToast('Enter customer name');return;}
    if(!sr){showToast('Enter Shawarma Small rate');return;}
    const old=state.editingCustomer;
    if(old && old!==newName){
        delete state.data.customers[old];
        for(const d of Object.keys(state.data.daily)){
            if(state.data.daily[d][old]!==undefined){
                state.data.daily[d][newName]=state.data.daily[d][old];
                delete state.data.daily[d][old];
            }
        }
    }
    state.data.customers[newName]={shawarma_small_rate:sr,shawarma_large_rate:lr,burger_rate:br,butter_rate:bpr,mayo_rate:mr,opening_outstanding:op};
    persistData(); resetCustomerForm(); renderCustomerList(); buildQuickList();
    showToast(old?'Customer updated':'Customer added');
}

function editCustomer(name) {
