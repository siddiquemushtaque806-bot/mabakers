<script>
'use strict';

/* ================================================================
   CONSTANTS & STATE
================================================================ */
const PASSWORDS   = { '0000': 'manager', '9900': 'owner' };
const SYNC_URL    = 'https://mabakers.bonto.run/api/sync';
const SYNC_INTERVAL_MS = 5 * 60 * 1000; // 5 minutes

let state = {
    data:     { customers: {}, daily: {} },
    role:     null,   // 'owner' | 'manager' | null
    syncTimer: null,
    editingCustomer: null,   // name string when editing
    historyCustomer: null,   // name string for history page
};

/* ================================================================
   STORAGE — read / write
================================================================ */
function persistData() {
    const json = JSON.stringify(state.data);
    try {
        if (window.AndroidBridge) {
            window.AndroidBridge.saveData(json);
        } else {
            localStorage.setItem('mabakers_v2', json);
        }
    } catch (_) {
        localStorage.setItem('mabakers_v2', json);
    }
}

function loadData() {
    try {
        let raw = null;
        if (window.AndroidBridge) {
            raw = window.AndroidBridge.loadData();
        }
        if (!raw) {
            raw = localStorage.getItem('mabakers_v2')
               || localStorage.getItem('mabakers'); // legacy key
        }
        if (raw) {
            const parsed = JSON.parse(raw);
            if (isValidAppData(parsed)) {
                state.data = parsed;
            }
        }
    } catch (_) { /* keep default empty state */ }
}

function isValidAppData(obj) {
    return obj
        && typeof obj === 'object'
        && obj.customers && typeof obj.customers === 'object'
        && obj.daily     && typeof obj.daily     === 'object';
}

/* ================================================================
   UTILITY HELPERS
================================================================ */
function todayISO() {
    return new Date().toISOString().split('T')[0];
}

function firstOfMonthISO() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-01`;
}

function fmtMoney(n) {
    return 'Rs ' + Math.round(n).toLocaleString('en-PK');
}

function n(id) { return parseFloat(document.getElementById(id).value) || 0; }
function v(id) { return (document.getElementById(id).value || '').trim(); }
function set(id, val) { document.getElementById(id).value = val; }

/* ================================================================
   TOAST
================================================================ */
let _toastTimer = null;
function showToast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

/* ================================================================
   STATUS BAR
================================================================ */
let _statusTimers = {};
function showStatus(id, msg, type) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg;
    el.className = `status-bar show ${type}`;
    clearTimeout(_statusTimers[id]);
    _statusTimers[id] = setTimeout(() => el.classList.remove('show'), 4000);
}

/* ================================================================
   NAVIGATION
================================================================ */
function navigateTo(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));

    const pageEl = document.getElementById(`page-${page}`);
    const navEl  = document.getElementById(`nav-${page}`);

    if (pageEl) pageEl.classList.add('active');
    if (navEl)  navEl.classList.add('active');

    // Side effects per page
    if (page === 'daily')       buildQuickList();
    if (page === 'outstanding') renderOutstanding();
}

/* ================================================================
   DATE HELPERS
================================================================ */
function shiftDate(inputId, delta) {
    const el = document.getElementById(inputId);
    const d  = new Date(el.value);
    d.setDate(d.getDate() + delta);
    el.value = d.toISOString().split('T')[0];
}

/* ================================================================
   AUTHENTICATION
================================================================ */
function handleLogin() {
    const pwd = document.getElementById('login-input').value;
    const role = PASSWORDS[pwd];

    if (role) {
        state.role = role;
        localStorage.setItem('ma_role', role);
        applyRole();
        document.getElementById('login-screen').classList.add('hidden');
        startAutoSync();
        buildQuickList();
    } else {
        const errEl = document.getElementById('login-error');
        errEl.classList.add('show');
        document.getElementById('login-input').value = '';
        setTimeout(() => errEl.classList.remove('show'), 2500);
    }
}

function handleLogout() {
    state.role = null;
    localStorage.removeItem('ma_role');
    stopAutoSync();
    document.getElementById('login-input').value = '';
    document.getElementById('login-screen').classList.remove('hidden');
    showToast('Logged out successfully');
}

function applyRole() {
    const isManager = state.role === 'manager';
    document.body.classList.toggle('manager-mode', isManager);
    document.getElementById('header-role').textContent = isManager ? 'Manager' : 'Owner';
}

/* ================================================================
   SYNC
================================================================ */
function startAutoSync() {
    stopAutoSync();
    state.syncTimer = setInterval(syncSilent, SYNC_INTERVAL_MS);
}

function stopAutoSync() {
    if (state.syncTimer) {
        clearInterval(state.syncTimer);
        state.syncTimer = null;
    }
}

async function syncSilent() {
    try {
        const res = await fetch(SYNC_URL, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(state.data),
        });
        if (res.ok) {
            const merged = await res.json();
            if (isValidAppData(merged)) {
                state.data = merged;
                persistData();
                refreshAllViews();
            }
        }
    } catch (_) { /* silent — no internet */ }
}

async function syncData() {
    showToast('Syncing…');
    try {
        const res = await fetch(SYNC_URL, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(state.data),
        });
        if (!res.ok) { showToast('Sync failed — server error'); return; }
        const merged = await res.json();
        if (isValidAppData(merged)) {
            state.data = merged;
            persistData();
            refreshAllViews();
            showToast('✓ Synced successfully');
        } else {
            showToast('Sync error — data protected');
        }
    } catch (_) {
        showToast('No internet connection');
    }
}

function refreshAllViews() {
    renderCustomerList();
    renderOutstanding();
    buildQuickList();
}

/* ================================================================
   OUTSTANDING CALCULATION
================================================================ */

/**
 * Returns the outstanding balance for a customer just before a given date.
 * Looks at all entries with date < targetDate, picks the most recent one.
 */
function getPrevOutstanding(customerName, targetDate) {
    const daily = state.data.daily;
    const priorDates = Object.keys(daily)
        .filter(d => daily[d][customerName] !== undefined && d < targetDate)
        .sort();

    if (priorDates.length > 0) {
        return daily[priorDates[priorDates.length - 1]][customerName].outstanding || 0;
    }

    // No prior entries — use opening balance
    const customer = state.data.customers[customerName];
    return customer ? (customer.opening_outstanding || 0) : 0;
}

/**
 * After editing/saving an entry for a customer on a given date,
 * cascade-recalculate all future entries for that customer
 * so outstanding stays consistent.
 */
function cascadeRecalc(customerName, fromDate) {
    const daily = state.data.daily;
    const futureDates = Object.keys(daily)
        .filter(d => daily[d][customerName] !== undefined && d > fromDate)
        .sort(); // ascending — must process in order

    for (const date of futureDates) {
        const entry = daily[date][customerName];
        const prevOut = getPrevOutstanding(customerName, date);
        entry.prev_outstanding = prevOut;
        entry.outstanding      = prevOut + entry.day_total - entry.payment;
    }
}

