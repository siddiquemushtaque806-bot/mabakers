/* ================================================================
   BILL GENERATION
================================================================ */
function generateBill(name, from, to) {
    const daily = state.data.daily;

    // Get dates ascending
    const dates = Object.keys(daily)
        .filter(d => daily[d][name] !== undefined && d >= from && d <= to)
        .sort();

    if (!dates.length) { showToast('No entries in this period'); return; }

    // Determine which product columns are needed
    const cols = {
        small:  dates.some(d => (daily[d][name].shawarma_small_qty  || 0) > 0),
        large:  dates.some(d => (daily[d][name].shawarma_large_qty  || 0) > 0),
        burger: dates.some(d => (daily[d][name].burger_qty           || 0) > 0),
        butter: dates.some(d => (daily[d][name].butter_qty           || 0) > 0),
        mayo:   dates.some(d => (daily[d][name].mayo_qty             || 0) > 0),
        rent:   dates.some(d => (daily[d][name].rent                 || 0) > 0),
    };

    // Header row
    let th = '<th>Date</th>';
    if (cols.small)  th += '<th>Small</th>';
    if (cols.large)  th += '<th>Large</th>';
    if (cols.burger) th += '<th>Burger</th>';
    if (cols.butter) th += '<th>Butter</th>';
    if (cols.mayo)   th += '<th>Mayo</th>';
    if (cols.rent)   th += '<th>Rent</th>';
    th += '<th>Total</th>';

    // Data rows + totals
    let totals = { small:0, large:0, burger:0, butter:0, mayo:0, rent:0, grand:0 };
    let tbody   = '';

    // Newest first in table
    [...dates].reverse().forEach(d => {
        const e = daily[d][name];
        let td  = `<td>${d}</td>`;
        if (cols.small)  { td += `<td>${e.shawarma_small_qty  || ''}</td>`; totals.small  += e.shawarma_small_qty  || 0; }
        if (cols.large)  { td += `<td>${e.shawarma_large_qty  || ''}</td>`; totals.large  += e.shawarma_large_qty  || 0; }
        if (cols.burger) { td += `<td>${e.burger_qty           || ''}</td>`; totals.burger += e.burger_qty          || 0; }
        if (cols.butter) { td += `<td>${e.butter_qty           || ''}</td>`; totals.butter += e.butter_qty          || 0; }
        if (cols.mayo)   { td += `<td>${e.mayo_qty             || ''}</td>`; totals.mayo   += e.mayo_qty            || 0; }
        if (cols.rent)   { td += `<td>${e.rent ? Math.round(e.rent) : ''}</td>`; totals.rent += e.rent || 0; }
        td += `<td>${Math.round(e.day_total || 0).toLocaleString('en-PK')}</td>`;
        totals.grand += e.day_total || 0;
        tbody += `<tr>${td}</tr>`;
    });

    // Summary rows
    let summaryRows = '';
    if (cols.small)  summaryRows += `<tr><td>Shawarma Small</td><td>${totals.small} pcs</td></tr>`;
    if (cols.large)  summaryRows += `<tr><td>Shawarma Large</td><td>${totals.large} pcs</td></tr>`;
    if (cols.burger) summaryRows += `<tr><td>Burger</td><td>${totals.burger} pcs</td></tr>`;
    if (cols.butter) summaryRows += `<tr><td>Butter Paper</td><td>${totals.butter} pcs</td></tr>`;
    if (cols.mayo)   summaryRows += `<tr><td>Mayonnaise</td><td>${totals.mayo} pcs</td></tr>`;
    if (cols.rent)   summaryRows += `<tr><td>Total Rent</td><td>Rs ${Math.round(totals.rent).toLocaleString('en-PK')}</td></tr>`;

    // Outstanding block (owner only)
    const latestDate  = dates[dates.length - 1]; // last date in range
    const latestEntry = daily[latestDate][name];
    const outstanding = latestEntry.outstanding || 0;

    const outRows = state.role === 'owner'
        ? `<tr><td>Total Paid</td><td style="color:green">Rs ${Math.round(latestEntry.payment||0).toLocaleString('en-PK')}</td></tr>
           <tr class="outstanding-row"><td>Outstanding Balance</td>
               <td style="color:${outstanding <= 0 ? 'green' : 'red'}">
                   ${outstanding <= 0 ? 'PAID ✓' : 'Rs ' + Math.round(outstanding).toLocaleString('en-PK')}
               </td>
           </tr>`
        : '';

    const billHTML = `
        <div class="bill-header-section">
            <div class="bill-company">M.A BAKERS</div>
            <div class="bill-company-sub">SHAWARMA</div>
        </div>
        <div class="bill-meta">
            <span><strong>M/s:</strong> ${name}</span>
            <span><strong>Date:</strong> ${new Date().toLocaleDateString('en-PK')}</span>
        </div>
        <div class="bill-meta">
            <span><strong>Period:</strong> ${from} &nbsp;to&nbsp; ${to}</span>
        </div>
        <table class="bill-table">
            <thead><tr>${th}</tr></thead>
            <tbody>${tbody}</tbody>
        </table>
        <table class="bill-summary-table">
            <tr class="section-head"><td colspan="2">SUMMARY</td></tr>
            ${summaryRows}
            <tr class="total-row"><td>Total Amount</td><td>Rs ${Math.round(totals.grand).toLocaleString('en-PK')}</td></tr>
            ${outRows}
        </table>
        <div class="bill-footer">
            <p>Generated: ${new Date().toLocaleString('en-PK')}</p>
            <p style="margin-top:28px">_______________________</p>
            <p>Authorised Signature</p>
        </div>
    `;

    document.getElementById('bill-body').innerHTML = billHTML;
    document.getElementById('bill-overlay').classList.add('show');

    // Share button
    document.getElementById('share-btn').onclick = () => shareBill(name, from, to);
}

function closeBill() {
    document.getElementById('bill-overlay').classList.remove('show');
}

function shareBill(name, from, to) {
    const text = buildBillText(name, from, to);
    if (navigator.share) {
        navigator.share({ title: `Bill — ${name}`, text })
            .catch(() => copyText(text));
    } else {
        copyText(text);
    }
}

function buildBillText(name, from, to) {
    const daily = state.data.daily;
    const dates = Object.keys(daily)
        .filter(d => daily[d][name] !== undefined && d >= from && d <= to)
        .sort();

    let text  = `*M.A BAKERS — SHAWARMA*\n`;
    text     += `M/s: ${name}\n`;
    text     += `Period: ${from} to ${to}\n`;
    text     += `─────────────────────\n`;

    let grand = 0;
    dates.forEach(d => {
        const e    = daily[d][name];
        let   line = `${d}: `;
        if (e.shawarma_small_qty)  line += `Small ${e.shawarma_small_qty} `;
        if (e.shawarma_large_qty)  line += `Large ${e.shawarma_large_qty} `;
        if (e.burger_qty)          line += `Burger ${e.burger_qty} `;
        if (e.butter_qty)          line += `Butter ${e.butter_qty} `;
        if (e.mayo_qty)            line += `Mayo ${e.mayo_qty} `;
        if (e.rent)                line += `Rent Rs${Math.round(e.rent)} `;
        line  += `= *Rs ${Math.round(e.day_total||0).toLocaleString('en-PK')}*`;
        text  += line + '\n';
        grand += e.day_total || 0;
    });

    text += `─────────────────────\n`;
    text += `*Total: Rs ${Math.round(grand).toLocaleString('en-PK')}*\n`;

    if (state.role === 'owner') {
        const latestDate  = dates[dates.length - 1];
        const latestEntry = daily[latestDate][name];
        const out         = latestEntry?.outstanding || 0;
        text += `*Outstanding: ${out <= 0 ? 'PAID ✓' : 'Rs ' + Math.round(out).toLocaleString('en-PK')}*\n`;
    }

    return text;
}

function copyText(text) {
    const el = document.createElement('textarea');
    el.value = text;
    el.style.position = 'fixed';
    el.style.opacity  = '0';
    document.body.appendChild(el);
    el.select();
    try { document.execCommand('copy'); showToast('✓ Bill copied — paste in WhatsApp'); }
    catch (_) { showToast('Could not copy'); }
    document.body.removeChild(el);
}

/* ================================================================
   SPLASH & INIT
================================================================ */
function initSplash() {
    setTimeout(() => {
        document.getElementById('splash-ring').classList.add('show');
        document.getElementById('splash-title').classList.add('show');
        document.getElementById('splash-sub').classList.add('show');
        document.getElementById('splash-line').classList.add('show');
    }, 100);

    setTimeout(() => {
        const splash = document.getElementById('splash');
        splash.style.transition = 'opacity 0.8s ease';
        splash.style.opacity    = '0';

        setTimeout(() => {
            splash.remove();
            const savedRole = localStorage.getItem('ma_role');
            if (savedRole && PASSWORDS[Object.keys(PASSWORDS).find(k => PASSWORDS[k] === savedRole)]) {
                state.role = savedRole;
                applyRole();
                startAutoSync();
                buildQuickList();
            } else {
                document.getElementById('login-screen').classList.remove('hidden');
            }
        }, 800);
    }, 3000);
}

function initDates() {
    const t = todayISO();
    const now = new Date();
    set('quick-date',  t);
    set('detail-date', t);
    set('sum-date',    t);
    set('hist-date',   t);
    set('ch-from',     firstOfMonthISO());
    set('ch-to',       t);
    set('mon-year',    now.getFullYear());
    set('mon-month',   String(now.getMonth() + 1).padStart(2, '0'));
}

