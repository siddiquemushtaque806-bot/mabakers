function saveCustomer() {
    const newName  = v('cf-name');
    const smallRate = parseFloat(document.getElementById('cf-small').value)  || 0;
    const largeRate = parseFloat(document.getElementById('cf-large').value)  || 0;
    const burgerRate= parseFloat(document.getElementById('cf-burger').value) || 0;
    const butterRate= parseFloat(document.getElementById('cf-butter').value) || 0;
    const mayoRate  = parseFloat(document.getElementById('cf-mayo').value)   || 0;
    const opening   = parseFloat(document.getElementById('cf-opening').value)|| 0;

    if (!newName)      { showToast('Please enter customer name');         return; }
    if (!smallRate)    { showToast('Please enter Shawarma Small rate');   return; }

    const oldName = state.editingCustomer;

    // If renaming, migrate all historical daily entries to new name
    if (oldName && oldName !== newName) {
        delete state.data.customers[oldName];
        for (const date of Object.keys(state.data.daily)) {
            if (state.data.daily[date][oldName] !== undefined) {
                state.data.daily[date][newName] = state.data.daily[date][oldName];
                delete state.data.daily[date][oldName];
            }
        }
    }

    state.data.customers[newName] = {
        shawarma_small_rate: smallRate,
        shawarma_large_rate: largeRate,
        burger_rate:         burgerRate,
        butter_rate:         butterRate,
        mayo_rate:           mayoRate,
        opening_outstanding: opening,
    };

    persistData();
    resetCustomerForm();
    renderCustomerList();
    buildQuickList();
    showToast(oldName ? 'Customer updated' : 'Customer added');
}

function editCustomer(name) {
    const c = state.data.customers[name];
    state.editingCustomer = name;

    set('cf-name',    name);
    set('cf-small',   c.shawarma_small_rate || '');
    set('cf-large',   c.shawarma_large_rate || '');
    set('cf-burger',  c.burger_rate         || '');
    set('cf-butter',  c.butter_rate         || '');
    set('cf-mayo',    c.mayo_rate           || '');
    set('cf-opening', c.opening_outstanding || '');

    document.getElementById('customer-form-title').textContent = 'Edit Customer';
    document.getElementById('cf-save-btn').textContent         = 'Update Customer';

    navigateTo('customers');
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function deleteCustomer(name) {
    if (!confirm(`Delete "${name}"?\n\nThis will remove the customer. All history entries will be kept.`)) return;
    delete state.data.customers[name];
    persistData();
    renderCustomerList();
    buildQuickList();
    showToast(`${name} deleted`);
}

function resetCustomerForm() {
    state.editingCustomer = null;
    ['cf-name','cf-small','cf-large','cf-burger','cf-butter','cf-mayo','cf-opening']
        .forEach(id => set(id, ''));
    document.getElementById('customer-form-title').textContent = 'Add Customer';
    document.getElementById('cf-save-btn').textContent         = 'Save Customer';
}

